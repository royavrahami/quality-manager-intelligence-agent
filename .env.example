# ─────────────────────────────────────────────────────────────────────────────
# QA Intelligence Agent – Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o          # gpt-4o for best quality; gpt-4o-mini for lower cost
OPENAI_MAX_TOKENS=2000

# ── GitHub (optional – increases rate limits from 60 to 5000 req/hr) ─────────
GITHUB_TOKEN=ghp_...

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/qa_agent.db

# ── Scheduler ─────────────────────────────────────────────────────────────────
# How often the agent runs (in hours). Default: every 6 hours.
SCHEDULE_INTERVAL_HOURS=6

# ── Email Notifications ───────────────────────────────────────────────────────
# Sends the FULL HTML report to your inbox after every agent run.
#
# Gmail setup (2 minutes):
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Create App Password:        https://myaccount.google.com/apppasswords
#      → Select "Mail" + your device → Copy the 16-char password
#   3. Fill in the values below:
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.gmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
NOTIFY_EMAIL=your.gmail@gmail.com

# Slack (optional)
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL=#qa-intelligence

# ── Relevance Scoring ─────────────────────────────────────────────────────────
# Minimum relevance score (0-100) required for AI summarisation and report inclusion.
# Lower = more articles processed (higher OpenAI cost); higher = more selective.
# Recommended: 40 (balanced). Use 60+ for a stricter, shorter report.
MIN_RELEVANCE_SCORE=40

# ── Reports ───────────────────────────────────────────────────────────────────
REPORTS_DIR=./reports

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs
